# Postgres credentials — used by docker-compose.dev.yml directly
POSTGRES_USER=crisley
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=claridge

# Connection string for uvicorn running on the host (outside Docker).
# Port 5433 matches the host-side mapping in docker-compose.dev.yml.
# When running inside Docker, DATABASE_URL is overridden by the compose file.
DATABASE_URL=postgresql+asyncpg://claridge:secret@localhost:5433/claridge
